# ── Go ──────────────────────────────────────────────────────────────
/bin/
/dist/
*.exe
*.test
*.out
coverage.*
vendor/
go.work.sum

# ── Frontend (web/) ─────────────────────────────────────────────────
web/node_modules/
# Ignore built assets but keep the dir (with its placeholder) so the Go embed
# in web/embed.go always compiles, even before a frontend build.
web/dist/*
!web/dist/.gitkeep
web/.vite/
*.local
# Playwright's run output: traces and screenshots of a failed run, useful
# locally and as a CI artifact, never something to commit.
web/test-results/
web/playwright-report/
web/blob-report/
web/.playwright/

# ── Secrets / runtime (never commit) ────────────────────────────────
*.pem
*.key
secrets.env
/etc-local/
*.sqlite
*.db

# ── Editor / OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp

# Claude Code local files
.claude/settings.local.json
